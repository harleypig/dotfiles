#!/usr/bin/env bash

# vmgr - orchestrate per-language version/toolchain managers.
#
# Wraps each language's NATIVE manager (nvm, perlbrew, pipx, uv, ...) behind a
# single verb-based entry point, rather than adopting an off-the-shelf unified
# tool. See docs/adr/0001-custom-polyglot-version-manager.md for the why.
#
# Usage:
#   vmgr <action> [language [manager ...]]
#
#   actions: install | update | remove | report
#            list | help
#
#   vmgr install node             install node's manager(s)
#   vmgr install python uv        install just python's uv manager
#   vmgr install python pipx uv   install both of python's managers
#   vmgr update python pipx       update one of python's managers
#   vmgr remove python uv         remove python's uv manager
#   vmgr report node              report expected vs current state, flag drift
#   vmgr help python              show python's help (all its managers)
#   vmgr install                  (no language) list what's available
#   vmgr list                     list available languages and their managers
#   vmgr help                     this general usage
#
# ONE language per invocation. The args after it are that language's managers;
# with none named, a multi-manager language (e.g. `vmgr install python`) lists
# its managers so you can pick (report/help instead act on all of them).
#
# Each language is a sourced module in lib/version-managers/<language> that
# declares `vmgr_managers=(...)` and one function per verb and manager:
# <manager>_install, _update, _remove, _report, _help. A language whose
# managers are mutually exclusive enforces that within the module itself (its
# install logic), not the dispatcher. Override the module dir with VMGR_LIB_DIR
# (test suite).

set -uo pipefail

###############################################################################
# Setup

# Resolve our real path through any invoking symlink to locate lib/.
self=$(readlink -f "${BASH_SOURCE[0]}")
bindir=$(dirname "$self")

: "${VMGR_LIB_DIR:=$bindir/../lib/version-managers}"

PROG=${0##*/}

# Verbs that dispatch to a manager (<manager>_<verb>). `list` is handled
# separately (no per-language dispatch). report/help are "informational" - on a
# multi-manager language with no manager named, they act on ALL managers rather
# than listing.
readonly VALID_ACTIONS=" install update remove report help "
readonly INFO_ACTIONS=" report help "

###############################################################################
# Utility functions

#------------------------------------------------------------------------------
# Print an error to stderr and exit with the given code (default 1).

die() {
  local code=1

  if [[ $1 == -* ]]; then
    code=${1#-}
    shift
  fi

  printf '%s: %s\n' "$PROG" "$*" >&2
  exit "$code"
}

#------------------------------------------------------------------------------
# Print usage to stdout: the leading comment block (from the title line to the
# first blank line), with the comment markers stripped. Robust to the block
# growing, unlike a hardcoded line range.

usage() {
  sed -n '/^# vmgr - /,/^$/{s/^# \{0,1\}//;p;}' "$self"
}

#------------------------------------------------------------------------------
# Echo the managers a language module declares, one per line. Sourced in a
# subshell so the module's definitions never leak into the dispatcher.

language_managers() {
  local module=$1

  (
    unset vmgr_managers
    # shellcheck disable=SC1090  # module path is resolved at runtime
    source "$module" > /dev/null 2>&1 || exit 1
    # shellcheck disable=SC2154  # assigned by the sourced language module
    printf '%s\n' "${vmgr_managers[@]}"
  )
}

#------------------------------------------------------------------------------
# List every available language and the managers it provides.

list_available() {
  local -a modules=()
  mapfile -t modules < <(find "$VMGR_LIB_DIR" -maxdepth 1 -type f | sort)

  if ((${#modules[@]} == 0)); then
    printf 'No version-manager modules found in %s\n' "$VMGR_LIB_DIR"
    return 0
  fi

  printf 'Available version managers (language: managers):\n'

  local module lang
  for module in "${modules[@]}"; do
    lang=${module##*/}

    local -a managers=()
    mapfile -t managers < <(language_managers "$module")

    printf '  %s: %s\n' "$lang" "${managers[*]:-(none)}"
  done
}

###############################################################################
# Dispatch

#------------------------------------------------------------------------------
# True if <name> is a known language (has a module in VMGR_LIB_DIR).

is_language() {
  [[ -f "$VMGR_LIB_DIR/$1" ]]
}

#------------------------------------------------------------------------------
# True if <needle> (first arg) equals one of the remaining args.

in_list() {
  local needle=$1
  shift

  local item
  for item in "$@"; do
    [[ $item == "$needle" ]] && return 0
  done

  return 1
}

#------------------------------------------------------------------------------
# Run <action> for one language target: the language ($2) plus zero or more
# explicitly-named managers (the rest). With no manager named, a modifying
# action on a multi-manager language lists the managers instead of acting,
# while an informational action (report/help) acts on all of them. Returns
# non-zero on any error. Sourced in a subshell by the caller so module
# definitions don't leak between targets.

handle_target() {
  local action=$1 lang=$2
  shift 2
  local -a want=("$@")

  unset vmgr_managers
  # shellcheck disable=SC1090  # module path is resolved at runtime
  source "$VMGR_LIB_DIR/$lang" || {
    printf '%s: failed to load %s module\n' "$PROG" "$lang" >&2
    return 1
  }

  local -a have=("${vmgr_managers[@]:-}")
  ((${#have[@]} && ${#have[0]})) || {
    printf '%s: %s module declares no managers\n' "$PROG" "$lang" >&2
    return 1
  }

  local -a act=()
  if ((${#want[@]})); then
    # Every named manager must belong to this language.
    local m
    for m in "${want[@]}"; do
      in_list "$m" "${have[@]}" || {
        printf '%s: %s is not a manager of %s (managers: %s)\n' \
          "$PROG" "$m" "$lang" "${have[*]}" >&2
        return 1
      }
    done
    act=("${want[@]}")

  elif ((${#have[@]} > 1)) && [[ $INFO_ACTIONS != *" $action "* ]]; then
    printf '%s has multiple managers; name one or more:\n' "$lang"
    printf '  %s\n' "${have[@]}"
    return 0

  else
    act=("${have[@]}")
  fi

  local rc=0 mgr fn n=0
  for mgr in "${act[@]}"; do
    fn="${mgr}_${action}"
    declare -F "$fn" > /dev/null || {
      printf '%s: %s/%s does not support %s\n' "$PROG" "$lang" "$mgr" "$action" >&2
      rc=1
      continue
    }

    # Blank line between successive informational (report/help) outputs.
    ((n++ > 0)) && [[ $INFO_ACTIONS == *" $action "* ]] && printf '\n'

    "$fn" || rc=1
  done

  return "$rc"
}

###############################################################################
# Main

main() {
  local action=${1:-list}
  shift || true

  case $action in
    -h | --help)
      usage
      exit 0
      ;;

    list)
      list_available
      exit 0
      ;;

    help)
      # `vmgr help` with no targets is the general usage; `help <targets>`
      # falls through to the positional dispatch below (action=help).
      (($#)) || {
        usage
        exit 0
      }
      ;;
  esac

  [[ $VALID_ACTIONS == *" $action "* ]] \
    || die -2 "unknown action '$action' (expected: install, update, remove, report, help, list)"

  # No language -> list what's available.
  (($#)) || {
    list_available
    exit 0
  }

  # One language per invocation; the remaining args are its managers.
  local lang=$1
  shift
  is_language "$lang" \
    || die "unknown language '$lang' (one language per invocation)"

  # Subshell isolates the module's sourced definitions.
  (handle_target "$action" "$lang" "$@")
  exit $?
}

main "$@"
