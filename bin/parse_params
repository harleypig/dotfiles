#!/usr/bin/env perl

#############################################################################
# parse_params - validate CLI/function parameters against a definition string
# and emit shell variable assignments for the caller to `eval`.
#
# This is a self-contained, core-perl-only rewrite of the old bash
# lib/parse_params (which depended on a long-gone `utility` library and is
# therefore unrunnable). Because a subprocess cannot set variables in the
# caller's shell, it prints `eval`-able assignments instead of mutating the
# caller directly.
#
# Only quoted DATA is emitted (plus a bare `exit 0` for --help) -- never
# generated code -- so `eval`-ing the output is safe.
#############################################################################

use strict;
use warnings;

use Getopt::Long   ();
use File::Basename qw(dirname);
use File::Spec     ();

my $PROG = 'parse_params';

my @TYPES   = qw(boolean char date filename integer string varname);
my %IS_TYPE = map { $_ => 1 } @TYPES;

# Set from leading options in main; read by the error/usage helpers below.
our $AUTO      = 0;                    # --auto: handle errors itself (usage + emit `exit 2`)
our $PROG_NAME = '';                   # --prog NAME: shown in the generated usage header
our ( $OPTS, $POSITIONALS );

#############################################################################
# Documentation
#
#=head1 NAME
#
# parse_params - validate parameters from a definition string, emit shell
# assignments.
#
#=head1 SYNOPSIS
#
#   PARM_DEF='
#   a|app,string,AppName,,required
#   v|verbose,boolean
#   n|num,integer,count,0
#   i|inc,string@,includes
#   #,string,target
#   '
#   _pp=$(parse_params "$PARM_DEF" "$@") || show_usage
#   eval "$_pp"
#   # now: $AppName, $verbose (0/1), $count, "${includes[@]}", $target
#
# Generate usage text from a definition (for the caller's own show_usage):
#
#   parse_params --usage [--prog NAME] "$PARM_DEF"
#
# Or fully turnkey -- parse_params prints errors + usage and emits `exit`
# itself, so no show_usage is needed:
#
#   eval "$(parse_params --auto --prog "${0##*/}" "$PARM_DEF" "$@")"
#
# Works in a function too -- pass the function's "$@"; declare the target vars
# `local` first to scope them to the function. A function with many parameters
# is usually better off as its own script.
#
# `parse_params -h` / `--help` prints parse_params's own reference.
#
#=head1 DEFINITION LINES
#
# One option per line, up to five comma-separated fields (surrounding
# whitespace is trimmed):
#
#   OPTION, TYPE, VARNAME, DEFAULT, REQUIRED
#
# OPTION   short (`a`), long (`app`), both (`a|app`), or `#` for a positional.
# TYPE     one of: boolean char date filename integer string varname.
#          Append `@` (e.g. `string@`) to collect repeats into a shell array.
# VARNAME  optional; defaults to the long option, else the short option.
# DEFAULT  optional; used when the option is absent (ignored for boolean).
# REQUIRED optional; `required` or `optional` (default optional; boolean is
#          always optional).
#
#=head1 BEHAVIOR / EXIT CODES
#
#   boolean   set -> 1, absent -> 0 (so `((VAR)) && ...` fires when given).
#             Negatable: --no-LONG sets 0. DEFAULT 0|1 sets the resting value,
#             so DEFAULT=1 is a default-on (inverted) flag.
#   integer   signed: /^-?\d+$/.
#   filename  parent dir must exist and the file be readable (or creatable);
#             emitted as an absolute path.
#   date      accepted if `date -d VALUE` succeeds.
#
#   exit 0    success (assignments on stdout), or --help (usage on stderr).
#   exit 1    invalid input (messages on stderr).
#   exit 2    invalid definition -- a developer error in PARM_DEF.
#############################################################################

#----------------------------------------------------------------------------
# Error helpers.

# Bad input from the caller's user. In --auto mode parse_params handles it
# itself: print the messages + generated usage to STDERR and emit `exit 2` on
# STDOUT (so the caller's `eval` stops the script); otherwise exit 1 and let
# the caller's `|| show_usage` handle it.
sub bail_input {
  print STDERR "$PROG: $_\n" for @_;
  if ($AUTO) {
    print STDERR "\n", build_usage( $OPTS, $POSITIONALS ) if defined $OPTS;
    print "exit 2\n";
    exit 0;
  }
  exit 1;
}

# Broken definition -- a developer error in PARM_DEF. In --auto mode also emit
# `exit 2` so the caller's `eval` stops rather than running with unset vars.
sub def_err {
  print STDERR "$PROG: definition error: $_[0]\n";
  if ($AUTO) { print "exit 2\n"; exit 0; }
  exit 2;
}

#----------------------------------------------------------------------------
# Single-quote a value for safe shell eval.

sub shq {
  my $s = shift;
  $s = '' unless defined $s;
  $s =~ s/'/'\\''/g;
  return "'$s'";
}

#----------------------------------------------------------------------------
# Type validation. An empty value is always acceptable here (a missing
# required value is caught separately); validators only judge a present value.

sub valid_filename {
  my $p   = shift;
  my $dir = dirname($p);

  return 0 unless -d $dir;
  return -r $p   ? 1 : 0 if -e $p;
  return -w $dir ? 1 : 0;
}

sub valid_date {
  my $v = shift;

  # Pass the value as $1 to sh so it is never interpreted as shell.
  return system( 'sh', '-c', 'date -d "$1" >/dev/null 2>&1', 'sh', $v ) == 0
    ? 1
    : 0;
}

sub valid_value {
  my ( $type, $v ) = @_;

  return 1 unless defined $v && length $v;

  return 1 if $type eq 'string';
  return length($v) == 1 ? 1 : 0 if $type eq 'char';
  return $v =~ /^-?\d+$/        ? 1 : 0 if $type eq 'integer';
  return $v =~ /^[A-Za-z_]\w*$/ ? 1 : 0 if $type eq 'varname';
  return valid_filename($v) if $type eq 'filename';
  return valid_date($v)     if $type eq 'date';

  return 1;
}

#----------------------------------------------------------------------------
# Parse the definition string into option/positional descriptors.

sub parse_definition {
  my $def = shift;

  my ( @opts, @positionals, @optspec, %values );
  my ( %seen_short, %seen_long );

  for my $raw ( split /\n/, $def ) {
    ( my $line = $raw ) =~ s/^\s+|\s+$//g;
    next unless length $line;

    my @f = $line =~ /,/ ? split( /\s*,\s*/, $line, -1 ) : split( /\s+/, $line );
    my ( $opt, $type, $var, $default, $req ) = @f;

    def_err("missing OPTION in: $line") unless defined $opt && length $opt;

    # Positional parameter.
    if ( $opt eq '#' ) {
      def_err("positional needs a TYPE in: $line")
        unless defined $type && length $type;
      ( my $ptype = $type ) =~ s/\@$//;
      def_err("unknown type ($type) in: $line") unless $IS_TYPE{$ptype};
      def_err("positional needs a VARNAME in: $line")
        unless defined $var && length $var;
      def_err("invalid variable name ($var) in: $line")
        unless $var =~ /^[A-Za-z_]\w*$/;

      push @positionals, { type => $ptype, var => $var };
      next;
    }

    def_err("missing TYPE in: $line") unless defined $type && length $type;

    my $repeat = ( $type =~ s/\@$// );
    def_err("unknown type ($type) in: $line") unless $IS_TYPE{$type};
    def_err("boolean cannot be repeatable (\@) in: $line")
      if $repeat && $type eq 'boolean';

    my ( $short, $long );
    if ( $opt =~ /\|/ ) {
      ( $short, $long ) = split /\|/, $opt, 2;
      def_err("short option must be one char ($opt) in: $line")
        unless length($short) == 1;
      def_err("long option missing after | ($opt) in: $line")
        unless length($long);
    } elsif ( length($opt) == 1 ) {
      $short = $opt;
    } else {
      $long = $opt;
    }

    if ( defined $short ) {
      def_err("repeated short option ($short) in: $line")
        if $seen_short{$short}++;
    }
    if ( defined $long ) {
      def_err("repeated long option ($long) in: $line")
        if $seen_long{$long}++;
    }

    $var = ( defined $long ? $long : $short )
      unless defined $var && length $var;
    def_err("invalid variable name ($var) in: $line")
      unless $var =~ /^[A-Za-z_]\w*$/;

    $req = defined $req && length $req ? lc $req : 'optional';
    $req = 'optional' if $type eq 'boolean';
    def_err("REQUIRED must be required|optional ($req) in: $line")
      unless $req eq 'required' || $req eq 'optional';

    my $name = join '|', grep { defined } ( $short, $long );

    if ( $type eq 'boolean' ) {
      def_err("boolean DEFAULT must be 0 or 1 ($default) in: $line")
        if defined $default && length $default && $default !~ /^[01]$/;
      $values{$var} = undef;

      # Negatable: -v / --verbose set 1, --no-verbose sets 0. With DEFAULT=1
      # this gives a default-on (inverted) flag.
      push @optspec, "$name!" => \$values{$var};
    } elsif ($repeat) {
      $values{$var} = [];
      push @optspec, "$name=s@" => $values{$var};
    } else {
      $values{$var} = undef;
      push @optspec, "$name=s" => \$values{$var};
    }

    push @opts,
      { short   => $short,
        long    => $long,
        var     => $var,
        type    => $type,
        repeat  => $repeat,
        default => ( defined $default && length $default ? $default : undef ),
        req     => $req,
      };
  } ## end for my $raw ( split /\n/...)

  def_err('definition has no options or positionals')
    unless @opts || @positionals;

  return ( \@opts, \@positionals, \@optspec, \%values );
} ## end sub parse_definition

#----------------------------------------------------------------------------
# Build human-readable usage text from the option descriptors.

sub build_usage {
  my ( $opts, $positionals ) = @_;

  my $prog  = length $PROG_NAME ? "$PROG_NAME " : '';
  my @lines = ( "Usage: ${prog}[options]" . ( @$positionals ? ' ' . join( ' ', map { $_->{var} } @$positionals ) : '' ) . "\n" );

  if (@$opts) {
    push @lines, 'Options:';
    for my $o (@$opts) {
      my @flags;
      push @flags, "-$o->{short}" if defined $o->{short};
      push @flags, "--$o->{long}" if defined $o->{long};
      my $flag = join ', ', @flags;
      my $meta =
          $o->{type} eq 'boolean' ? ''
        : $o->{repeat}            ? " <$o->{type}>..."
        :                           " <$o->{type}>";
      my @notes;
      push @notes, 'required'               if $o->{req} eq 'required';
      push @notes, "default: $o->{default}" if defined $o->{default};
      my $note = @notes ? '  (' . join( '; ', @notes ) . ')' : '';
      push @lines, sprintf( '  %s%s%s', $flag, $meta, $note );
    }
  } ## end if (@$opts)

  if (@$positionals) {
    push @lines, 'Positional:';
    push @lines, "  $_->{var} <$_->{type}>" for @$positionals;
  }

  return join( "\n", @lines ) . "\n";
} ## end sub build_usage

#----------------------------------------------------------------------------
# parse_params's own help (the leading -h/--help), distinct from the usage it
# generates for a caller (--usage, or a caller program's own -h).

sub tool_help {
  print <<'EOH';
parse_params - validate parameters from a definition string and emit
eval-able shell assignments (replaces hand-written arg-parsing loops).

Usage:
  parse_params [--auto] [--prog NAME] "$DEF" "$@"   # parse; print assignments
  parse_params --usage [--prog NAME] "$DEF"         # print generated usage
  parse_params -h | --help                          # this help

In a script (or a function -- pass the function's "$@"):
  PARM_DEF='
  a|app,string,AppName,,required
  v|verbose,boolean
  n|num,integer,count,0
  i|inc,string@,includes
  #,string,target
  '
  _pp=$(parse_params "$PARM_DEF" "$@") || show_usage   # show_usage runs
  eval "$_pp"                                          #   parse_params --usage
  # ...or fully turnkey (no show_usage needed):
  eval "$(parse_params --auto --prog "${0##*/}" "$PARM_DEF" "$@")"

Definition line (comma-separated; trailing fields optional):
  OPTION, TYPE, VARNAME, DEFAULT, REQUIRED
  OPTION    short (a), long (app), both (a|app), or # for a positional
  TYPE      boolean char date filename integer string varname
            append @ (e.g. string@) to collect repeats into a shell array
  VARNAME   defaults to the long option, else the short option
  DEFAULT   used when the option is absent (boolean: 0|1 resting value)
  REQUIRED  required | optional (default optional)

Behavior:
  boolean   set -> 1, absent -> 0; negatable (--no-LONG); DEFAULT=1 default-on
  integer   signed
  filename  parent dir must exist, file readable or creatable; emitted absolute
  date      accepted if `date -d VALUE` succeeds

Exit codes: 0 ok / 1 bad input / 2 bad definition.
EOH
  exit 0;
} ## end sub tool_help

#############################################################################
# Main.

# Leading parse_params options precede the definition string. A definition
# line never starts with '-', so the first non-option arg is the definition.
my $usage_mode = 0;
while ( @ARGV && substr( $ARGV[0], 0, 1 ) eq '-' ) {
  my $a = $ARGV[0];

  if ( $a eq '-h' || $a eq '--help' ) {
    tool_help();                       # parse_params's own help; exits 0
  } elsif ( $a eq '--usage' ) {
    $usage_mode = 1;
    shift @ARGV;
  } elsif ( $a eq '--auto' ) {
    $AUTO = 1;
    shift @ARGV;
  } elsif ( $a eq '--prog' ) {
    shift @ARGV;
    @ARGV or def_err('--prog needs a value');
    $PROG_NAME = shift @ARGV;
  } elsif ( $a eq '--' ) {
    shift @ARGV;
    last;
  } else {
    last;                              # unrecognized; treat the next arg as the definition
  }
} ## end while ( @ARGV && substr( ...))

@ARGV or def_err('no definition string given');

my $def  = shift @ARGV;
my @args = @ARGV;

my ( $optspec, $values );
( $OPTS, $POSITIONALS, $optspec, $values ) = parse_definition($def);

if ($usage_mode) {
  print build_usage( $OPTS, $POSITIONALS );
  exit 0;
}

# A program built on parse_params gets --help for free: if the caller's args
# include -h/--help (and the caller did not define its own), print the
# generated usage and tell the caller's `eval` to stop cleanly. (parse_params's
# own --help is the leading flag handled above.)
my %defined_flag = map { ( $_->{short} // '' ) => 1, ( $_->{long} // '' ) => 1 } @$OPTS;
if ( !$defined_flag{h} && !$defined_flag{help} ) {
  for my $a (@args) {
    last if $a eq '--';
    if ( $a eq '-h' || $a eq '--help' ) {
      print STDERR build_usage( $OPTS, $POSITIONALS );
      print "exit 0\n";
      exit 0;
    }
  }
}

Getopt::Long::Configure( 'no_auto_abbrev', 'no_ignore_case', 'permute' );
{
  # Getopt::Long warns to STDERR on a bad option; let that through, then fail.
  Getopt::Long::GetOptionsFromArray( \@args, @$optspec )
    or bail_input('could not parse options');
}

my @errors;
my @out;

for my $o (@$OPTS) {
  my $var  = $o->{var};
  my $type = $o->{type};

  if ( $type eq 'boolean' ) {
    my $bv =
        defined $values->{$var} ? ( $values->{$var} ? 1 : 0 )
      : defined $o->{default}   ? $o->{default}
      :                           0;
    push @out, "$var=$bv";
    next;
  }

  if ( $o->{repeat} ) {
    my @vals = @{ $values->{$var} };
    @vals = ( $o->{default} ) if !@vals && defined $o->{default};

    for my $v (@vals) {
      push @errors, "--$o->{long} ($v) is not a $type"
        if !valid_value( $type, $v );
    }
    push @errors, "$var is required" if $o->{req} eq 'required' && !@vals;

    @vals = map { $type eq 'filename' ? File::Spec->rel2abs($_) : $_ } @vals
      if $type eq 'filename';
    push @out, "$var=(" . join( ' ', map { shq($_) } @vals ) . ')';
    next;
  }

  my $v = $values->{$var};
  $v = $o->{default} if !defined $v && defined $o->{default};

  if ( defined $v && length $v && !valid_value( $type, $v ) ) {
    push @errors, "value ($v) for $var is not a $type";
  }
  push @errors, "$var is required"
    if $o->{req} eq 'required' && !( defined $v && length $v );

  $v = File::Spec->rel2abs($v) if $type eq 'filename' && defined $v && length $v;
  push @out, "$var=" . shq($v);
} ## end for my $o (@$OPTS)

# Positionals: assign the leftover args in order.
for my $p (@$POSITIONALS) {
  my $v = shift @args;
  if ( defined $v && length $v && !valid_value( $p->{type}, $v ) ) {
    push @errors, "positional $p->{var} ($v) is not a $p->{type}";
  }
  $v = File::Spec->rel2abs($v)
    if $p->{type} eq 'filename' && defined $v && length $v;
  push @out, "$p->{var}=" . shq($v);
}

bail_input(@errors) if @errors;

print "$_\n" for @out;
exit 0;
