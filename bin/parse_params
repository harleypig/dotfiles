#!/usr/bin/env perl

#############################################################################
# parse_params - validate CLI/function parameters against a definition string
# and emit shell variable assignments for the caller to `eval`.
#
# This is a self-contained, core-perl-only rewrite of the old bash
# lib/parse_params (which depended on a long-gone `utility` library and is
# therefore unrunnable). Because a subprocess cannot set variables in the
# caller's shell, it prints `eval`-able assignments instead of mutating the
# caller directly.
#
# Only quoted DATA is emitted (plus a bare `exit 0` for --help) -- never
# generated code -- so `eval`-ing the output is safe.
#############################################################################

use strict;
use warnings;

use Getopt::Long   ();
use File::Basename qw(dirname);
use File::Spec     ();
use Pod::Usage     qw(pod2usage);

my $PROG = 'parse_params';

my @TYPES   = qw(boolean char date filename integer string varname);
my %IS_TYPE = map { $_ => 1 } @TYPES;

# Cross-option constraint kinds (declared on '%' lines; see CONSTRAINTS in the
# POD). Each relates two or more option VARNAMEs.
my @CONSTRAINTS   = qw(exclusive require-one together implies);
my %IS_CONSTRAINT = map { $_ => 1 } @CONSTRAINTS;

# Set from leading options in main; read by the error/usage helpers below.
my $AUTO      = 0;                     # --auto: handle errors itself (usage + emit `exit 2`)
my $PROG_NAME = '';                    # --prog NAME: shown in the generated usage header
my ( $OPTS, $POSITIONALS );

#----------------------------------------------------------------------------
# Error helpers.

# Bad input from the caller's user. In --auto mode parse_params handles it
# itself: print the messages + generated usage to STDERR and emit `exit 2` on
# STDOUT (so the caller's `eval` stops the script); otherwise exit 1 and let
# the caller's `|| show_usage` handle it.
sub bail_input {
  my @msgs = @_;
  print STDERR "$PROG: $_\n" for @msgs;
  if ($AUTO) {
    print STDERR "\n", build_usage( $OPTS, $POSITIONALS ) if defined $OPTS;
    print "exit 2\n";
    exit 0;
  }
  exit 1;
}

# Broken definition -- a developer error in PARM_DEF. In --auto mode also emit
# `exit 2` so the caller's `eval` stops rather than running with unset vars.
sub def_err {
  print STDERR "$PROG: definition error: $_[0]\n";
  if ($AUTO) { print "exit 2\n"; exit 0; }
  exit 2;
}

#----------------------------------------------------------------------------
# Single-quote a value for safe shell eval.

sub shq {
  my $s = shift;
  $s = '' unless defined $s;
  $s =~ s/'/'\\''/g;
  return "'$s'";
}

#----------------------------------------------------------------------------
# Type validation. An empty value is always acceptable here (a missing
# required value is caught separately); validators only judge a present value.

sub valid_filename {
  my $p   = shift;
  my $dir = dirname($p);

  return 0 unless -d $dir;
  return -r $p   ? 1 : 0 if -e $p;
  return -w $dir ? 1 : 0;
}

sub valid_date {
  my $v = shift;

  # Pass the value as $1 to sh so it is never interpreted as shell.
  return system( 'sh', '-c', 'date -d "$1" >/dev/null 2>&1', 'sh', $v ) == 0
    ? 1
    : 0;
}

# TYPE => sub returning true for a valid (non-empty) value. To add a type, add
# it to @TYPES and (if it has a value to check) here. boolean has no value;
# any type without an entry passes.
my %CHECK = (
  char     => sub { length $_[0] == 1 },
  integer  => sub { $_[0] =~ /^-?\d+$/ },
  varname  => sub { $_[0] =~ /^[A-Za-z_]\w*$/ },
  filename => \&valid_filename,
  date     => \&valid_date,
);

sub valid_value {
  my ( $type, $v ) = @_;

  return 1 unless defined $v && length $v;

  my $check = $CHECK{$type} or return 1;
  return $check->($v) ? 1 : 0;
}

#----------------------------------------------------------------------------
# Parse the definition string into option/positional descriptors.

sub parse_definition {
  my $def = shift;

  my ( @opts, @positionals, @optspec, %values, @constraints );
  my ( %seen_short, %seen_long );

  for my $raw ( split /\n/, $def ) {
    ( my $line = $raw ) =~ s/^\s+|\s+$//g;
    next unless length $line;

    my @f = $line =~ /,/ ? split( /\s*,\s*/, $line, -1 ) : split( /\s+/, $line );
    my ( $opt, $type, $var, $default, $req ) = @f;

    def_err("missing OPTION in: $line") unless defined $opt && length $opt;

    # Constraint line. OPTION '%' declares a cross-option rule:
    #   %, KIND, VARNAME, VARNAME[, ...]
    # KIND is one of @CONSTRAINTS; the members are option VARNAMEs (validated
    # against the parsed options once the whole definition is read, below).
    if ( $opt eq '%' ) {
      my ( $kind, @vars ) = @f[ 1 .. $#f ];
      def_err("constraint needs a KIND in: $line")
        unless defined $kind && length $kind;
      $kind = lc $kind;
      def_err("unknown constraint kind ($kind) in: $line")
        unless $IS_CONSTRAINT{$kind};
      @vars = grep { defined && length } @vars;
      def_err("constraint ($kind) needs at least two VARNAMEs in: $line")
        unless @vars >= 2;

      push @constraints, { kind => $kind, vars => \@vars, line => $line };
      next;
    }

    # Positional parameter. OPTION '#' is one fixed positional; '#@' is a
    # slurp that collects ALL remaining args into a shell array. A slurp must
    # be the last positional, and there can be only one.
    if ( $opt eq '#' || $opt eq '#@' ) {
      my $slurp = $opt eq '#@';
      def_err("positional needs a TYPE in: $line")
        unless defined $type && length $type;
      def_err("unknown type ($type) in: $line") unless $IS_TYPE{$type};
      def_err("positional needs a VARNAME in: $line")
        unless defined $var && length $var;
      def_err("invalid variable name ($var) in: $line")
        unless $var =~ /^[A-Za-z_]\w*$/;
      def_err("a slurp positional (#\@) must be the last one in: $line")
        if @positionals && $positionals[-1]{slurp};

      push @positionals, { type => $type, var => $var, slurp => $slurp };
      next;
    }

    def_err("missing TYPE in: $line") unless defined $type && length $type;

    my $repeat = ( $type =~ s/\@$// );
    def_err("unknown type ($type) in: $line") unless $IS_TYPE{$type};
    def_err("boolean cannot be repeatable (\@) in: $line")
      if $repeat && $type eq 'boolean';

    my ( $short, $long );
    if ( $opt =~ /\|/ ) {
      ( $short, $long ) = split /\|/, $opt, 2;
      def_err("short option must be one char ($opt) in: $line")
        unless length($short) == 1;
      def_err("long option missing after | ($opt) in: $line")
        unless length($long);
    } elsif ( length($opt) == 1 ) {
      $short = $opt;
    } else {
      $long = $opt;
    }

    if ( defined $short ) {
      def_err("repeated short option ($short) in: $line")
        if $seen_short{$short}++;
    }
    if ( defined $long ) {
      def_err("repeated long option ($long) in: $line")
        if $seen_long{$long}++;
    }

    $var = ( defined $long ? $long : $short )
      unless defined $var && length $var;
    def_err("invalid variable name ($var) in: $line")
      unless $var =~ /^[A-Za-z_]\w*$/;

    $req = defined $req && length $req ? lc $req : 'optional';
    $req = 'optional' if $type eq 'boolean';
    def_err("REQUIRED must be required|optional ($req) in: $line")
      unless $req eq 'required' || $req eq 'optional';

    my $name = join '|', grep { defined } ( $short, $long );

    if ( $type eq 'boolean' ) {
      def_err("boolean DEFAULT must be 0 or 1 ($default) in: $line")
        if defined $default && length $default && $default !~ /^[01]$/;
      $values{$var} = undef;

      # Negatable: -v / --verbose set 1, --no-verbose sets 0. With DEFAULT=1
      # this gives a default-on (inverted) flag.
      push @optspec, "$name!" => \$values{$var};
    } elsif ($repeat) {
      $values{$var} = [];
      push @optspec, "$name=s@" => $values{$var};
    } else {
      $values{$var} = undef;
      push @optspec, "$name=s" => \$values{$var};
    }

    push @opts,
      { short   => $short,
        long    => $long,
        var     => $var,
        type    => $type,
        repeat  => $repeat,
        default => ( defined $default && length $default ? $default : undef ),
        req     => $req,
      };
  } ## end for my $raw ( split /\n/...)

  def_err('definition has no options or positionals')
    unless @opts || @positionals;

  # Resolve constraint members against the defined options now that every
  # option is known (so a '%' line may appear before the options it names).
  my %opt_by_var = map { $_->{var} => 1 } @opts;
  for my $c (@constraints) {
    for my $v ( @{ $c->{vars} } ) {
      def_err("constraint ($c->{kind}) references unknown option ($v) in: $c->{line}")
        unless $opt_by_var{$v};
    }
  }

  return ( \@opts, \@positionals, \@optspec, \%values, \@constraints );
} ## end sub parse_definition

#----------------------------------------------------------------------------
# Build human-readable usage text from the option descriptors.

sub build_usage {
  my ( $opts, $positionals ) = @_;

  my $prog = length $PROG_NAME ? "$PROG_NAME " : '';
  my $args = join ' ',
    map { $_->{slurp} ? "[$_->{var}...]" : $_->{var} } @$positionals;
  my @lines = ( "Usage: ${prog}[options]" . ( length $args ? " $args" : '' ) . "\n" );

  if (@$opts) {
    push @lines, 'Options:';
    for my $o (@$opts) {
      my @flags;
      push @flags, "-$o->{short}" if defined $o->{short};
      push @flags, "--$o->{long}" if defined $o->{long};
      my $flag = join ', ', @flags;
      my $meta =
          $o->{type} eq 'boolean' ? ''
        : $o->{repeat}            ? " <$o->{type}>..."
        :                           " <$o->{type}>";
      my @notes;
      push @notes, 'required'               if $o->{req} eq 'required';
      push @notes, "default: $o->{default}" if defined $o->{default};
      my $note = @notes ? '  (' . join( '; ', @notes ) . ')' : '';
      push @lines, sprintf( '  %s%s%s', $flag, $meta, $note );
    }
  } ## end if (@$opts)

  if (@$positionals) {
    push @lines, 'Positional:';
    push @lines,
      "  $_->{var} <$_->{type}>" . ( $_->{slurp} ? '...' : '' ) for @$positionals;
  }

  return join( "\n", @lines ) . "\n";
} ## end sub build_usage

#----------------------------------------------------------------------------
# Cross-option constraint checking. Constraints are judged on what the user
# actually PROVIDED, not on post-default values: %values holds undef-until-given
# (defaults fold in later, in the value loop), so a defaulted option never
# trips a constraint.

# Was this option supplied by the user? boolean -> set to a true value (1);
# repeatable -> at least one value; otherwise -> a non-empty value.
sub opt_active {
  my ( $o, $values ) = @_;
  my $v = $values->{ $o->{var} };

  return ( defined $v        && $v )        ? 1 : 0 if $o->{type} eq 'boolean';
  return ( ref $v eq 'ARRAY' && @$v )       ? 1 : 0 if $o->{repeat};
  return ( defined $v        && length $v ) ? 1 : 0;
}

# The flag a user types, for messages: prefer the long form, else the short.
sub opt_label {
  my $o = shift;
  return defined $o->{long} ? "--$o->{long}" : "-$o->{short}";
}

# Return the list of user-facing violation messages for all constraints.
sub check_constraints {
  my ( $constraints, $opts, $values ) = @_;

  my %by_var = map { $_->{var} => $_ } @$opts;
  my @errors;

  for my $c (@$constraints) {
    my @os     = map { $by_var{$_} } @{ $c->{vars} };
    my @labels = map { opt_label($_) } @os;
    my $set    = '(' . join( ', ', @labels ) . ')';
    my @active = grep { opt_active( $os[$_], $values ) } 0 .. $#os;

    if ( $c->{kind} eq 'exclusive' ) {
      push @errors,
        "only one of $set may be given (got " . join( ', ', map { $labels[$_] } @active ) . ')'
        if @active > 1;

    } elsif ( $c->{kind} eq 'require-one' ) {
      push @errors, "one of $set is required" unless @active;

    } elsif ( $c->{kind} eq 'together' ) {
      push @errors, "$set must be given together (all or none)"
        if @active && @active < @os;

    } elsif ( $c->{kind} eq 'implies' ) {
      if ( opt_active( $os[0], $values ) ) {
        my @missing = grep { !opt_active( $os[$_], $values ) } 1 .. $#os;
        push @errors,
          "$labels[0] requires (" . join( ', ', map { $labels[$_] } @missing ) . ')'
          if @missing;
      }
    }
  } ## end for my $c (@$constraints)

  return @errors;
} ## end sub check_constraints

#############################################################################
# Main.

# Leading parse_params options precede the definition string. A definition
# line never starts with '-', so the first non-option arg is the definition.
my $usage_mode = 0;
while ( @ARGV && substr( $ARGV[0], 0, 1 ) eq '-' ) {
  my $a = $ARGV[0];

  if ( $a eq '-h' || $a eq '--help' ) {

    # parse_params's own reference, rendered from the POD below; exits 0.
    pod2usage( -verbose => 2, -exitval => 0 );
  } elsif ( $a eq '--usage' ) {
    $usage_mode = 1;
    shift @ARGV;
  } elsif ( $a eq '--auto' ) {
    $AUTO = 1;
    shift @ARGV;
  } elsif ( $a eq '--prog' ) {
    shift @ARGV;
    @ARGV or def_err('--prog needs a value');
    $PROG_NAME = shift @ARGV;
  } elsif ( $a eq '--' ) {
    shift @ARGV;
    last;
  } else {
    last;                              # unrecognized; treat the next arg as the definition
  }
} ## end while ( @ARGV && substr( ...))

@ARGV or def_err('no definition string given');

my $def  = shift @ARGV;
my @args = @ARGV;

my ( $optspec, $values, $constraints );
( $OPTS, $POSITIONALS, $optspec, $values, $constraints ) = parse_definition($def);

if ($usage_mode) {
  print build_usage( $OPTS, $POSITIONALS );
  exit 0;
}

# A program built on parse_params gets --help for free: if the caller's args
# include -h/--help (and the caller did not define its own), print the
# generated usage and tell the caller's `eval` to stop cleanly. (parse_params's
# own --help is the leading flag handled above.)
my %defined_flag;
for my $o (@$OPTS) {
  $defined_flag{ $o->{short} } = 1 if defined $o->{short};
  $defined_flag{ $o->{long} }  = 1 if defined $o->{long};
}
if ( !$defined_flag{h} && !$defined_flag{help} ) {
  for my $a (@args) {
    last if $a eq '--';
    if ( $a eq '-h' || $a eq '--help' ) {
      print STDERR build_usage( $OPTS, $POSITIONALS );
      print "exit 0\n";
      exit 0;
    }
  }
}

Getopt::Long::Configure( 'no_auto_abbrev', 'no_ignore_case', 'permute' );
{
  # Getopt::Long warns to STDERR on a bad option; let that through, then fail.
  Getopt::Long::GetOptionsFromArray( \@args, @$optspec )
    or bail_input('could not parse options');
}

my @errors;
my @out;

for my $o (@$OPTS) {
  my $var  = $o->{var};
  my $type = $o->{type};

  if ( $type eq 'boolean' ) {
    my $bv =
        defined $values->{$var} ? ( $values->{$var} ? 1 : 0 )
      : defined $o->{default}   ? $o->{default}
      :                           0;
    push @out, "$var=$bv";
    next;
  }

  if ( $o->{repeat} ) {
    my @vals = @{ $values->{$var} };
    @vals = ( $o->{default} ) if !@vals && defined $o->{default};

    for my $v (@vals) {
      push @errors, "--$o->{long} ($v) is not a $type"
        if !valid_value( $type, $v );
    }
    push @errors, "$var is required" if $o->{req} eq 'required' && !@vals;

    @vals = map { $type eq 'filename' ? File::Spec->rel2abs($_) : $_ } @vals
      if $type eq 'filename';
    push @out, "$var=(" . join( ' ', map { shq($_) } @vals ) . ')';
    next;
  }

  my $v = $values->{$var};
  $v = $o->{default} if !defined $v && defined $o->{default};

  if ( defined $v && length $v && !valid_value( $type, $v ) ) {
    push @errors, "value ($v) for $var is not a $type";
  }
  push @errors, "$var is required"
    if $o->{req} eq 'required' && !( defined $v && length $v );

  $v = File::Spec->rel2abs($v) if $type eq 'filename' && defined $v && length $v;
  push @out, "$var=" . shq($v);
} ## end for my $o (@$OPTS)

# Positionals: assign the leftover args in order. A slurp (#@) takes all that
# remain, as a shell array.
for my $p (@$POSITIONALS) {
  if ( $p->{slurp} ) {
    my @vals = @args;
    @args = ();

    for my $v (@vals) {
      push @errors, "positional $p->{var} ($v) is not a $p->{type}"
        unless valid_value( $p->{type}, $v );
    }
    @vals = map { File::Spec->rel2abs($_) } @vals if $p->{type} eq 'filename';
    push @out, "$p->{var}=(" . join( ' ', map { shq($_) } @vals ) . ')';
    next;
  }

  my $v = shift @args;
  if ( defined $v && length $v && !valid_value( $p->{type}, $v ) ) {
    push @errors, "positional $p->{var} ($v) is not a $p->{type}";
  }
  $v = File::Spec->rel2abs($v)
    if $p->{type} eq 'filename' && defined $v && length $v;
  push @out, "$p->{var}=" . shq($v);
} ## end for my $p (@$POSITIONALS)

# Cross-option constraints, judged on what the user provided (see opt_active).
push @errors, check_constraints( $constraints, $OPTS, $values );

bail_input(@errors) if @errors;

print "$_\n" for @out;
exit 0;

__END__

=head1 NAME

parse_params - validate parameters from a definition string and emit
eval-able shell assignments

=head1 SYNOPSIS

  PARM_DEF='
  a|app,string,AppName,,required
  v|verbose,boolean
  n|num,integer,count,0
  i|inc,string@,includes
  #,string,target
  '
  _pp=$(parse_params "$PARM_DEF" "$@") || show_usage
  eval "$_pp"
  # now: $AppName, $verbose (0/1), $count, "${includes[@]}", $target

Fully turnkey (parse_params prints errors + usage and emits C<exit> itself,
so no C<show_usage> is needed):

  eval "$(parse_params --auto --prog "${0##*/}" "$PARM_DEF" "$@")"

Generate usage text for a caller's own C<show_usage>:

  parse_params --usage [--prog NAME] "$PARM_DEF"

=head1 DESCRIPTION

Replaces the hand-written C<while (($#)); do case $1 in ...> argument-parsing
loop. It validates the arguments against a definition string and prints
C<eval>-able shell assignments; only quoted data is emitted (plus a bare
C<exit> for C<--help> / C<--auto>), never generated code, so C<eval>-ing the
output is safe.

It works inside a function too: pass the function's C<"$@">, and declare the
target variables C<local> first if you want them scoped to the function. A
function with many parameters is usually better off as its own script.

=head1 OPTIONS

parse_params's own options precede the definition string:

=over 4

=item B<--usage> [B<--prog> I<NAME>] I<DEF>

Print the usage text generated from I<DEF> and exit.

=item B<--prog> I<NAME>

Use I<NAME> in the generated usage header (C<Usage: NAME [options] ...>).

=item B<--auto>

Turnkey error handling: on bad input or a broken definition, print the errors
and the usage to STDERR and emit C<exit 2> on STDOUT, so the caller's C<eval>
stops the script with no C<show_usage> needed.

=item B<-h>, B<--help>

Print this reference and exit. (A leading C<-h> is parse_params's own help; a
C<-h> in the caller's arguments, after I<DEF>, produces that program's
generated usage instead.)

=back

=head1 DEFINITION LINES

One option per line, up to five comma-separated fields (surrounding whitespace
is trimmed):

  OPTION, TYPE, VARNAME, DEFAULT, REQUIRED

=over 4

=item B<OPTION>

Short (C<a>), long (C<app>), both (C<a|app>), C<#> for a fixed positional, or
C<#@> for a slurp positional that collects all remaining args into a shell
array. A slurp must be the last positional, and there can be only one. C<%>
begins a B<constraint> line that relates several options (see
L</CONSTRAINTS>).

=item B<TYPE>

One of: boolean char date filename integer string varname. Append C<@>
(e.g. C<string@>) to collect repeats into a shell array.

=item B<VARNAME>

Optional; defaults to the long option, else the short option.

=item B<DEFAULT>

Optional; used when the option is absent. For C<boolean> it is the resting
value (C<0> or C<1>).

=item B<REQUIRED>

Optional; C<required> or C<optional> (default C<optional>; boolean is always
optional).

=back

=head1 CONSTRAINTS

A line whose OPTION field is C<%> declares a B<cross-option constraint> — a
rule relating two or more options that a single per-option field cannot
express:

  %, KIND, VARNAME, VARNAME[, ...]

The members are option B<VARNAME>s (the resolved variable — the long option,
else the short, else an explicit VARNAME field), not flag letters. A C<%> line
may appear anywhere in the definition, before or after the options it names.
Multiple groups are just multiple lines, and an option may appear in several.

Constraints are judged on what the user actually B<provided>, not on
post-default values: a boolean counts when set to a true value (C<--no-x> does
not), a repeatable when given at least once, any other option when given a
non-empty value. So a default never trips a constraint. A violation is an
input error (exit 1, or the usual C<--auto> handling); naming an unknown KIND
or VARNAME is a definition error (exit 2).

=over 4

=item B<exclusive>

At most one of the members may be provided ("mutually exclusive").

=item B<require-one>

At least one of the members must be provided.

=item B<together>

All or none — if any member is provided, every member must be.

=item B<implies>

Directional: if the B<first> member is provided, the remaining members are
required.

=back

C<exclusive> + C<require-one> over the same pair means "exactly one," e.g. a
dry-run/force toggle that must be chosen:

  n|dry-run,boolean,dry_run
  f|force,boolean
  a|all,boolean
  %,exclusive,dry_run,force
  %,require-one,dry_run,force

(C<dry-run> needs the explicit C<dry_run> VARNAME because a hyphenated long
option is not a valid shell variable.)

=head1 ARGUMENT ORDER

Options and positionals may be interleaved on the command line: recognized
options (with their values) are permuted out wherever they appear, and the
remaining arguments, in order, are the positionals — each fixed C<#> takes
one, then a C<#@> slurp takes the rest. So C<#@> must be the last positional in
the *definition*, but on the command line the options can come before, after,
or among the positional words.

A positional that begins with C<-> must come after C<--> (which ends option
parsing); otherwise it is taken as an unknown option and rejected.

=head1 TYPES AND BEHAVIOR

=over 4

=item boolean

Set -> C<1>, absent -> C<0>, so C<((VAR)) && ...> fires when the flag is
given. Negatable: C<--no-LONG> sets C<0>. C<DEFAULT=1> makes a default-on
(inverted) flag.

=item integer

Signed (C</^-?\d+$/>).

=item filename

The parent directory must exist and the file must be readable (or creatable);
emitted as an absolute path.

=item date

Accepted if C<date -d VALUE> succeeds.

=item char / string / varname

A single character / any non-empty value / a valid shell identifier.

=back

=head1 EXIT STATUS

  0   success (assignments on STDOUT), or --help / --usage
  1   invalid input (messages on STDERR)
  2   invalid definition -- a developer error in PARM_DEF

=cut
