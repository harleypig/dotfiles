#!/usr/bin/env bash

# Docker wrapper for hadolint (Dockerfile linter).
# Modelled on bin/shellcheck: mount $PWD as the container workdir and pass
# all arguments through. File arguments must be relative to $PWD.
#
# Image is pinned by digest (see rules/docker.md — never :latest). Bump the
# tag + digest together; resolve a new digest with:
#   docker buildx imagetools inspect hadolint/hadolint:<tag>
HADOLINT_IMAGE="hadolint/hadolint:v2.14.0-alpine@sha256:7aba693c1442eb31c0b015c129697cb3b6cb7da589d85c7562f9deb435a6657c"

#------------------------------------------------------------------------------
# Fail fast: all file arguments must be under $PWD (the container mount point).
for arg in "$@"; do
  [[ $arg == -* ]] && continue
  abs=$(realpath -- "$arg" 2> /dev/null) || continue
  if [[ $abs != "$PWD"/* ]]; then
    printf 'hadolint: %s is not under the current directory; cd to its parent or modify bin/hadolint\n' "$arg" >&2
    exit 1
  fi
done

#------------------------------------------------------------------------------
declare -a args=(
  --rm
  --user "$(id -u):$(id -g)"
  --volume "$PWD:/mnt"
  --workdir "/mnt"
)

# A repo-local .hadolint.yaml in $PWD takes precedence (hadolint searches the
# working directory first). The global config is mounted as the fallback that
# hadolint finds under $HOME/.config; HOME is set explicitly because --user
# with a non-container UID leaves it unset.
xdg_cfg="${XDG_CONFIG_HOME:-$HOME/.config}"
if [[ -f "$xdg_cfg/hadolint.yaml" ]]; then
  args+=(
    --env HOME=/home/hadolint
    --volume "$xdg_cfg/hadolint.yaml:/home/hadolint/.config/hadolint.yaml:ro"
  )
fi

#------------------------------------------------------------------------------
# The -alpine image sets no ENTRYPOINT (its CMD is `hadolint -`, reading from
# stdin), so invoke the binary explicitly to pass file arguments through.
exec docker run "${args[@]}" "$HADOLINT_IMAGE" hadolint "$@"
