#!/usr/bin/env bash

# git-all - Run git commands on all repositories under REPOHOME
#
# Usage: git-all [-Sv] [command...]
#
# Options:
#   -S  Show repos which have uncommitted changes
#       If specified, all other options are ignored
#   -v  Print error output in job summary for failed jobs
#
# Environment:
#   REPOHOME  Directory to search for git repos (default: $HOME)
#
# Originally from: https://github.com/falconindy/bin-scripts

set -euo pipefail

REPOHOME=${REPOHOME:-$HOME}
VERBOSE=0

count=0
declare -a fail
declare -a pass
declare -A output

print_error() {
  local msg=$1; shift
  printf "$(ansi fg red)::$(ansi off) ${msg}\n" "$@" >&2
}

print_header() {
  local msg=$1; shift
  printf " $(ansi fg green)==>$(ansi off)$(ansi bold) ${msg}$(ansi off)\n" "$@" >&2
}

print_subheader() {
  local msg=$1; shift
  printf " $(ansi fg blue)  ->$(ansi off)$(ansi bold) ${msg}$(ansi off)\n" "$@" >&2
}

print_success() {
  printf " $(ansi fg blue)[$(ansi fg bright_white)PASS$(ansi fg blue)] $(ansi fg cyan)%s$(ansi off)\n" "$1"
}

print_failure() {
  printf " $(ansi fg blue)[$(ansi fg red)FAIL$(ansi fg blue)] $(ansi fg cyan)%s$(ansi off)\n" "$1" >&2
}

die() { print_error "%s" "$*"; exit 1; }

breadlink() {
  local path="$1"
  if [[ -d $path ]]; then
    (cd "$path" && pwd -P)
  else
    printf "%s\n" "$path"
  fi
}

do_all_action() {
  local repo resolved
  IFS=$'\n' read -r -d $'\0' -a repos < <(find "$REPOHOME" -type d -name '.git' 2>/dev/null)

  for repo in "${repos[@]}"; do
    (( ++count ))
    resolved=$(breadlink "${repo%.git}")
    cd "$resolved"
    output[$resolved]=$(git "$@" 2>&1) && pass+=("$resolved") || fail+=("$resolved")
  done
}

stat_repos() {
  local repo resolved
  IFS=$'\n' read -r -d $'\0' -a repos < <(find "$REPOHOME" -type d -name '.git' 2>/dev/null)

  for repo in "${repos[@]}"; do
    resolved=$(breadlink "${repo%.git}")
    cd "$resolved"
    [[ -n $(git status -s | grep -v "^??") ]] && printf "%s\n" "$resolved"
  done
}

job_summary() {
  printf "\n"
  print_header "Job Summary For $count Repos: git %s" "$*"

  if [[ ${#fail[@]} -eq 0 ]]; then
    print_subheader "No errors were reported"
  else
    for repo in "${fail[@]}"; do
      print_failure "$repo"
      (( VERBOSE )) && { sed 's/^/   /' <<< "${output[$repo]}"; printf "\n"; } >&2
    done
  fi
  printf "\n"

  for repo in "${pass[@]}"; do
    print_success "$repo"
  done
  printf "\n"
}

[[ -r "$REPOHOME" ]] || die "Invalid \$REPOHOME: $REPOHOME"

while getopts :Sv flag; do
  case $flag in
    S) stat_repos; exit 0 ;;
    v) VERBOSE=1 ;;
    \?) die "invalid option -- '$OPTARG'" ;;
  esac
done

shift $(( OPTIND - 1 ))

[[ $# -gt 0 ]] || { sed -n '2,/^$/s/^# \?//p' "$0"; exit 1; }

do_all_action "$@"
job_summary "$@"
