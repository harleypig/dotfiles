#!/usr/bin/env bash

# Multi-call dispatcher for dockerized CLI tools and the local AI/LLM
# daemons. It is invoked through a symlink named for the tool; the
# basename of $0 selects which function to run. For example
#   bin/shellcheck -> docker_wrapper
# runs the shellcheck() function, which execs the shellcheck image.
#
# Add a tool:
#   1. write a <tool>() function below (build args, exec docker run)
#   2. register its image next to the function:
#      image[<tool>]='<repo>/<image>:<tag>' — the image[] keys ARE the
#      dispatchable-tool registry, so this one line registers the tool.
#   3. create the bin/<tool> symlink — `docker_wrapper-links --fix` creates
#      it for every registered-but-unlinked tool, or by hand:
#      ln -s docker_wrapper bin/<tool>
#
# Introspection (only when run by the real name, not a tool symlink):
#   docker_wrapper --known-tools   list registered tool names
#   docker_wrapper --images        list each tool and its docker image
# bin/docker_wrapper-links checks/repairs the bin/<tool> symlinks against
# --known-tools.
#
# Families (how each function is shaped):
#   pwd-mounted linters  shellcheck shfmt yamllint prettier hadolint
#                        markdownlint
#   scanners             trivy (pwd + socket)  dive (socket only)
#   daemons              ollama openwebui (host-gated, detached)
#
# IMAGE PINNING: trivy/hadolint/dive are pinned by digest per
# rules/docker.md (trivy was supply-chain compromised twice in 03/2026 —
# pin + run the image directly, never the marketplace actions). The
# linter images still use rolling tags; pinning them is queued in TODO.md.
# Each tool's image lives in the image[] array beside its function. Bump a
# tag + digest together with:
#   docker buildx imagetools inspect <image>:<tag>

set -uo pipefail

# Resolve our real path through the invoking symlink to locate lib/.
self=$(readlink -f "${BASH_SOURCE[0]}")
libdir=$(dirname "$self")/../lib

# shellcheck source=/dev/null
source "$libdir/docker_helpers"

tool=${0##*/}
export DW_TAG="${tool}: "

# Registry of dispatchable tools, keyed by tool name -> its docker image.
# Each function registers its image immediately after its definition, so a
# tool is dispatchable iff it has an image entry; removing a tool is one
# local edit (the function, its image[] line, and the symlink) with no
# dangling reference left in the dispatcher below. `--known-tools` and
# `--images` print this registry.
declare -A image=()

###############################################################################
# Tool functions. Each is invoked as `"$tool" "$@"`, so the function name
# shadows the host binary of the same name — exactly what we want.

#------------------------------------------------------------------------------
shellcheck() {
  dw_guard_pwd_paths shellcheck "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  # Forward SHELLCHECK_OPTS if set; the tool honours it in-container.
  [[ -n ${SHELLCHECK_OPTS-} ]] && args+=(--env "SHELLCHECK_OPTS=$SHELLCHECK_OPTS")

  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/shellcheckrc"
  if [[ -f $cfg ]]; then
    dw_set_home args /home/shellcheck
    dw_mount args "$cfg" /home/shellcheck/.shellcheckrc ro
  fi

  exec docker run "${args[@]}" "${image[shellcheck]}" "$@"
}
image[shellcheck]="koalaman/shellcheck:stable"

#------------------------------------------------------------------------------
shfmt() {
  dw_guard_pwd_paths shfmt "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  # Forward stdin when it is piped (not a TTY), so `shfmt ... < file` reaches
  # the container instead of an empty stream. bin/showvars relies on this with
  # `shfmt -tojson < script`; without -i the AST comes back empty.
  [[ -t 0 ]] || args+=(-i)

  exec docker run "${args[@]}" "${image[shfmt]}" "$@"
}
image[shfmt]="mvdan/shfmt:v3"

#------------------------------------------------------------------------------
yamllint() {
  dw_guard_pwd_paths yamllint "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  # Mount XDG config so yamllint finds /config/yamllint/config inside.
  local xdg="${XDG_CONFIG_HOME:-$HOME/.config}"
  if [[ -d $xdg/yamllint ]]; then
    dw_mount args "$xdg" /config ro
    args+=(--env "XDG_CONFIG_HOME=/config")
  fi

  exec docker run "${args[@]}" "${image[yamllint]}" "$@"
}
image[yamllint]="cytopia/yamllint:latest"

#------------------------------------------------------------------------------
# IaC tools (terraform / packer / tflint). Subcommand-driven, so they skip
# dw_guard_pwd_paths (args are subcommands/flags, not just file paths) — the
# caller passes pwd-relative targets. dw_user makes files that `terraform fmt` /
# `packer fmt` rewrite land host-owned, not root; HOME=/tmp gives a writable
# home under --user for any plugin/cache path.
terraform() {
  local -a args=(--rm --env HOME=/tmp)
  [[ -t 0 ]] || args+=(-i) # forward stdin so `terraform fmt -` works
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  exec docker run "${args[@]}" "${image[terraform]}" "$@"
}
image[terraform]="hashicorp/terraform:1.15"

#------------------------------------------------------------------------------
packer() {
  local -a args=(--rm --env HOME=/tmp)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  exec docker run "${args[@]}" "${image[packer]}" "$@"
}
image[packer]="hashicorp/packer:1.15"

#------------------------------------------------------------------------------
tflint() {
  local -a args=(--rm --env HOME=/tmp)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  exec docker run "${args[@]}" "${image[tflint]}" "$@"
}
image[tflint]="ghcr.io/terraform-linters/tflint:v0.63.1"

#------------------------------------------------------------------------------
prettier() {
  dw_guard_pwd_paths prettier "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  exec docker run "${args[@]}" "${image[prettier]}" "$@"
}
image[prettier]="prettier:latest"

#------------------------------------------------------------------------------
hadolint() {
  dw_guard_pwd_paths hadolint "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  # A repo-local .hadolint.yaml in $PWD wins (hadolint searches cwd
  # first); the global config is the fallback under $HOME/.config.
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/hadolint.yaml"
  if [[ -f $cfg ]]; then
    dw_set_home args /home/hadolint
    dw_mount args "$cfg" /home/hadolint/.config/hadolint.yaml ro
  fi

  # The -alpine image has no ENTRYPOINT (its CMD reads stdin), so name
  # the binary explicitly to pass file arguments through.
  exec docker run "${args[@]}" "${image[hadolint]}" hadolint "$@"
}
image[hadolint]="hadolint/hadolint:v2.14.0-alpine@sha256:7aba693c1442eb31c0b015c129697cb3b6cb7da589d85c7562f9deb435a6657c"

#------------------------------------------------------------------------------
markdownlint() {
  dw_guard_pwd_paths markdownlint "$@" || exit 1

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt)

  # The image entrypoint is markdownlint; the repo-local .markdownlint.json
  # is auto-discovered from /mnt (= $PWD).
  exec docker run "${args[@]}" "${image[markdownlint]}" "$@"
}
# SYNC: keep this tag in lock-step with the markdownlint-cli `rev:` in
# .pre-commit-config.yaml and .pre-commit-config-fix.yaml; bump all three
# together so the wrapper CLI and the pre-commit hook stay identical.
image[markdownlint]="ghcr.io/igorshubovych/markdownlint-cli:v0.48.0"

#------------------------------------------------------------------------------
trivy() {
  # Path guard, but skip the token after `image` (an image ref, not a
  # path) and the subcommand keywords themselves.
  local arg abs prev=""
  for arg in "$@"; do
    if [[ $arg == -* || $prev == image ]]; then
      prev="$arg"
      continue
    fi

    case $arg in
      image | fs | config | repo | rootfs | sbom | filesystem)
        prev="$arg"
        continue
        ;;
    esac

    abs=$(realpath -- "$arg" 2> /dev/null) || {
      prev="$arg"
      continue
    }

    if [[ -e $arg && $abs != "$PWD" && $abs != "$PWD"/* ]]; then
      dw_die 1 "${arg} is not under the current directory; cd to its parent or edit bin/docker_wrapper"
    fi

    prev="$arg"
  done

  # Persistent vuln-DB cache so it is not re-downloaded every run.
  local cache="${XDG_CACHE_HOME:-$HOME/.cache}/trivy"
  mkdir -p "$cache"

  local -a args=(--rm)
  dw_user args
  dw_mount args "$PWD" /mnt
  args+=(--workdir /mnt --env "TRIVY_CACHE_DIR=/cache")
  dw_mount args "$cache" /cache
  dw_docker_socket args

  exec docker run "${args[@]}" "${image[trivy]}" "$@"
}
image[trivy]="aquasec/trivy:0.71.0@sha256:016eae51fdcf989332a5404af7e8f625cd5d95d7c0907a221d080a996f556500"

#------------------------------------------------------------------------------
dive() {
  local -a args=(--rm)
  dw_user args
  dw_docker_socket args
  dw_tty_if_attached args

  # A repo-local .dive-ci configures the --ci efficiency thresholds.
  [[ -f $PWD/.dive-ci ]] && dw_mount args "$PWD/.dive-ci" /.dive-ci ro

  exec docker run "${args[@]}" "${image[dive]}" "$@"
}
image[dive]="wagoodman/dive:v0.13.1@sha256:f1886e6c32c094fc41a623c1989f5cb3e48aa766da5f0be233f911fc1d85ce10"

#------------------------------------------------------------------------------
ollama() {
  dw_require_host beaker

  # Idempotent ensure-up: start the container if it already exists
  # (running or stopped), else create it. Safe to call repeatedly — e.g.
  # openwebui() calls it as a dependency. No exec, so callers continue
  # afterward (`docker run -d` returns once the container is up).
  docker start ollama > /dev/null 2>&1 && return 0

  # --gpus=all needs the NVIDIA Container Toolkit + active proprietary
  # driver on the host; verify with `docker run --rm --gpus=all ubuntu
  # nvidia-smi`. --restart always brings it back after a reboot.
  local -a args=(
    -d
    --gpus=all
    -p 11434:11434
    -v ollama:/root/.ollama
    --name ollama
    --restart always
  )

  docker run "${args[@]}" "${image[ollama]}" > /dev/null
}
image[ollama]="ollama/ollama:latest"

#------------------------------------------------------------------------------
openwebui() {
  dw_require_host beaker

  # Open WebUI talks to Ollama, so make sure Ollama is up first.
  ollama

  # Reaches host Ollama via host.docker.internal:11434.
  local -a args=(
    -d
    -p 3000:8080
    --add-host=host.docker.internal:host-gateway
    -v open-webui:/app/backend/data
    --name open-webui
    --restart always
  )

  exec docker run "${args[@]}" "${image[openwebui]}"
}
image[openwebui]="ghcr.io/open-webui/open-webui:main"

###############################################################################
# Management interface — only when invoked by the real name (docker_wrapper),
# never via a tool symlink, so a stray symlink can't reach it. These print the
# registry as the single source of truth for external tooling (the
# bin/docker_wrapper-links symlink maintainer and the tests read them instead
# of parsing this file).
if [[ $tool == docker_wrapper ]]; then
  case ${1-} in
    --known-tools)
      printf '%s\n' "${!image[@]}" | sort
      exit 0
      ;;
    --images)
      while IFS= read -r _t; do
        printf '%-12s %s\n' "$_t" "${image[$_t]}"
      done < <(printf '%s\n' "${!image[@]}" | sort)
      exit 0
      ;;
  esac
fi

###############################################################################
# Dispatch: only registered tools (those with an image[] entry) may be
# invoked — a stray symlink must not be able to call an arbitrary shell
# function.
[[ -v image[$tool] ]] \
  || dw_die 2 "unknown tool '${tool}' — symlink bin/docker_wrapper as one of: ${!image[*]}"

"$tool" "$@"
