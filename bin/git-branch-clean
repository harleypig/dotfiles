#!/bin/bash
#
# git-branch-clean - Delete local branches that no longer exist on remote
#
# Usage: git branch-clean [-n|-f] [-a] [-h]
#
# Options:
#   -n  Dry run - show what would be deleted
#   -f  Force delete branches (required for actual deletion)
#   -a  Include branches never pushed to remote
#   -h  Show this help message
#
# Exactly one of -n / -f must be given: parse_params enforces that with
# `exclusive` + `require-one` constraints (see the global bash.md "Argument
# Parsing"), replacing the old hand-written mutual-exclusion / require checks.

# shellcheck disable=SC2154  # dry_run/force/all are set by the parse_params eval

##############################################################################
# Setup and Sanity
set -euo pipefail

bindir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

##############################################################################
# Functions

#-----------------------------------------------------------------------------
remove_branch() {
  local branch="$1"
  local reason="$2"

  if [[ -n $branch ]]; then
    if ((dry_run)); then
      echo "Would delete branch: $branch ($reason)"

    elif ((force)); then
      echo "Deleting branch: $branch"
      git branch -D "$branch"
    fi
  fi
}

##############################################################################
# Parse options. parse_params supplies -h/--help and enforces "exactly one of
# -n/-f" itself: --auto prints the error + usage and stops on a bad combination
# (none given, or both) or value.
git rev-parse --git-dir &> /dev/null || {
  echo "git-branch-clean: not a git repository" >&2
  exit 1
}

PARM_DEF='
n,boolean,dry_run
f,boolean,force
a,boolean,all
%,exclusive,dry_run,force
%,require-one,dry_run,force
'

eval "$("$bindir/parse_params" --auto --prog "${0##*/}" "$PARM_DEF" "$@")"

##############################################################################
# Fetch and prune to ensure we have current remote information
git fetch --prune

# Get all branch information at once
# For each branch, output: branch_name<tab>reason
readarray -t branches < <(
  {
    # Get branches with gone upstreams
    git for-each-ref --format '%(refname) %(upstream:track)' refs/heads \
      | awk '$2 == "[gone]" {sub("refs/heads/", "", $1); print $1 "\tremote branch gone"}'

    # If -a specified, get branches never pushed
    if ((all)); then
      git branch -vv \
        | awk '/^[^*]/ && ! /\[.*\]/ {
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", $1)
          print $1 "\tnever pushed"
        }'
    fi
  }
)

# Process all branches
for branch_info in "${branches[@]}"; do
  branch=${branch_info%%$'\t'*}
  reason=${branch_info#*$'\t'}
  remove_branch "$branch" "$reason"
done
