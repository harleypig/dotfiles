#!/bin/bash

##############################################################################
# Cleanup of a path variable (a string with values separated by colons).
#
# This script will remove duplicate paths and paths that don't exist. Cleanup
# will also reorder the values based on values in environment variables named
# SHOULD_BE_FIRST and SHOULD_BE_LAST, where the value is a colon separated
# list of paths in the order you want them to appear in the final output.
#
# There are also the SHOULD_BE_IGNORED and SHOULD_BE_STRIPPED environment
# variables. These are also colon separated string of paths. The order for
# these don't matter.
#
# SHOULD_BE_STRIPPED will remove the path from the final output. These values
# should be the same *as they appear in the original* because other entries
# may resolve to the same directory.
#
# SHOULD_BE_IGNORED will leave the path in it's original position in the final
# output. These values should be the same *as they appear in the original*.

#-----------------------------------------------------------------------------
warn() { printf '%s\n' "$@" >&2; }

die() {
  (($#)) && warn "$@"
  exit 1
}

debug() {
  ((DEBUG)) || return 0
  warn "$@"
}

#-----------------------------------------------------------------------------
# Resolve one entry and print "entry<TAB>resolved" iff it canonicalizes to an
# existing directory. Exported so xargs-spawned shells can call it.

_resolve_one() {
  local r
  r=$(readlink -ne "$1" 2> /dev/null) \
    && [[ -d $r ]] \
    && printf '%s\t%s\n' "$1" "$r"

  return 0
}
export -f _resolve_one

#-----------------------------------------------------------------------------
# Resolve many entries and fill the named assoc array with entry -> resolved
# dir (existing dirs only). Each readlink is a subprocess and PATH can hold
# many slow-to-stat entries (e.g. WSL /mnt/c), so fan the work out with
# `xargs -P` when it is available, falling back to a sequential loop where it
# is not. (GNU `parallel` is deliberately not used: for many tiny jobs its
# per-job startup makes it slower than even the sequential loop.)

resolve_dirs() {
  local -n _resolved=$1
  shift
  (($#)) || return 0

  local jobs orig real
  jobs=$(nproc 2> /dev/null) || jobs=4

  # SC2004 below: _resolved is an assoc array (the nameref hides its type),
  # so $orig is a path key, not an arithmetic index. SC2016 below: the
  # single-quoted "$0" is expanded by the xargs-spawned shell, not here.
  if printf '' | xargs -0 -P "$jobs" true 2> /dev/null; then
    while IFS=$'\t' read -r orig real; do
      # shellcheck disable=SC2004
      [[ -n $real ]] && _resolved[$orig]=$real
    done < <(
      # shellcheck disable=SC2016
      printf '%s\0' "$@" \
        | xargs -0 -P "$jobs" -n1 bash -c '_resolve_one "$0"'
    )

  else
    for orig in "$@"; do
      IFS=$'\t' read -r orig real < <(_resolve_one "$orig")
      # shellcheck disable=SC2004
      [[ -n $real ]] && _resolved[$orig]=$real
    done
  fi
}

#-----------------------------------------------------------------------------
# join with colon
# No, IFS=':' echo "$*" does not work.

jwc() {
  local IFS=':'
  echo "$*"
  return 0
}

#-----------------------------------------------------------------------------
# Classify and de-duplicate one entry into the named bucket array. Uses
# build_path's locals (strip_set, ignore_set, seen, resolved) via bash
# dynamic scope.

cp_add() {
  local e=$1
  local -n bucket=$2
  local r

  [[ -z $e || $e == '.' ]] && return 0
  [[ -v strip_set[$e] ]] && {
    debug "STRIP: $e"
    return 0
  }

  # Ignored entries are kept verbatim, in place, with no path resolution or
  # existence check; de-duplicated by their literal value.
  [[ -v ignore_set[$e] ]] && {
    [[ -v seen[$e] ]] && return 0
    seen[$e]=1
    bucket+=("$e")
    debug "IGNORE: $e"
    return 0
  }

  # Keep only real, existing directories (resolved up front, in parallel);
  # de-duplicate by resolved path.
  r=${resolved[$e]-}
  [[ -n $r ]] || return 0
  [[ -v strip_set[$r] ]] && {
    debug "STRIP: $r"
    return 0
  }
  [[ -v seen[$r] ]] && return 0
  seen[$r]=1
  bucket+=("$r")
  debug "DIR: $r"
}

#-----------------------------------------------------------------------------
# Build a cleaned value for the named variable. SHOULD_BE_FIRST/LAST/IGNORED/
# STRIPPED are colon-separated strings (see the header). FIRST/LAST entries
# are ordered ahead of / behind everything else.

build_path() {
  local path="${1?Must pass an environment variable name}"

  local -a first_list last_list strip_list ignore_list input
  local -a out_first out_middle out_last
  local -A first_set last_set strip_set ignore_set seen resolved candidates
  local entry

  IFS=':' read -ra first_list <<< "${SHOULD_BE_FIRST-}"
  IFS=':' read -ra last_list <<< "${SHOULD_BE_LAST-}"
  IFS=':' read -ra strip_list <<< "${SHOULD_BE_STRIPPED-}"
  IFS=':' read -ra ignore_list <<< "${SHOULD_BE_IGNORED-}"
  IFS=':' read -ra input <<< "${!path}"

  for entry in "${first_list[@]}"; do [[ -n $entry ]] && first_set[$entry]=1; done
  for entry in "${last_list[@]}"; do [[ -n $entry ]] && last_set[$entry]=1; done
  for entry in "${strip_list[@]}"; do [[ -n $entry ]] && strip_set[$entry]=1; done
  for entry in "${ignore_list[@]}"; do [[ -n $entry ]] && ignore_set[$entry]=1; done

  # Resolve every candidate's real directory once, in parallel. Ignored
  # entries are kept verbatim (cp_add never resolves them), so they are
  # excluded here; everything else (incl. strip candidates, which may be
  # stripped by their resolved path) is resolved.
  for entry in "${first_list[@]}" "${input[@]}" "${last_list[@]}"; do
    [[ -n $entry && $entry != '.' && ! -v ignore_set[$entry] ]] \
      && candidates[$entry]=1
  done

  resolve_dirs resolved "${!candidates[@]}"

  # FIRST entries (in order), then the input (FIRST/LAST members routed to
  # their bucket), then LAST entries (in order). cp_add de-dupes across all.
  for entry in "${first_list[@]}"; do cp_add "$entry" out_first; done

  for entry in "${input[@]}"; do
    if [[ -v first_set[$entry] ]]; then
      cp_add "$entry" out_first

    elif [[ -v last_set[$entry] ]]; then
      cp_add "$entry" out_last

    else
      cp_add "$entry" out_middle
    fi
  done

  for entry in "${last_list[@]}"; do cp_add "$entry" out_last; done

  jwc "${out_first[@]}" "${out_middle[@]}" "${out_last[@]}"

  return 0
}

#-----------------------------------------------------------------------------
[[ -z $1 ]] && die "No environment variable name passed as parameter."
[[ -z ${!1} ]] && die "Environment variable '$1' does not exist."

#-----------------------------------------------------------------------------
# Cleanup passed variable
debug "Cleaning $1 ..."

NEWVAR=$(build_path "$1")
printf '%s' "$NEWVAR"

#-----------------------------------------------------------------------------
# Don't clutter the environment in case we are being sourced.

unset -f _resolve_one resolve_dirs jwc build_path debug cp_add
unset NEWPATH NEWLDPATH SHOULD_BE_FIRST SHOULD_BE_LAST
unset SHOULD_BE_IGNORED SHOULD_BE_STRIPPED f
