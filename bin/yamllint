#!/usr/bin/env bash

# Docker wrapper for yamllint.

#------------------------------------------------------------------------------
# Fail fast: all file arguments must be under $PWD (the container mount point).
for arg in "$@"; do
  [[ $arg == -* ]] && continue
  abs=$(realpath -- "$arg" 2> /dev/null) || continue
  if [[ $abs != "$PWD"/* ]]; then
    printf 'yamllint: %s is not under the current directory; cd to its parent or modify bin/yamllint\n' "$arg" >&2
    exit 1
  fi
done

#------------------------------------------------------------------------------
declare -a args=(
  --rm
  --user "$(id -u):$(id -g)"
  --volume "$PWD:/mnt"
  --workdir "/mnt"
)

# Mount XDG yamllint config dir read-only; set XDG_CONFIG_HOME so yamllint
# finds the config at /config/yamllint/config inside the container.
xdg_cfg="${XDG_CONFIG_HOME:-$HOME/.config}"
if [[ -d "$xdg_cfg/yamllint" ]]; then
  args+=(
    --volume "$xdg_cfg:/config:ro"
    --env "XDG_CONFIG_HOME=/config"
  )
fi

#------------------------------------------------------------------------------
exec docker run "${args[@]}" cytopia/yamllint:latest "$@"
