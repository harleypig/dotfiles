#!/usr/bin/env bash

warn() { printf '%s\n' "$@" >&2; }

usage() {
  cat >&2 << 'EOF'
Usage: answer=$(yesno [-q] ['prompt'])

Prompt for a Y or N response. Reprompts on invalid input.

Options:
  -q, --quiet   Suppress warning on invalid input
  -h, --help    Show this help
EOF
  exit "${1:-0}"
}

#-----------------------------------------------------------------------------
: << POD
=head2 yesno

Usage: answer=E<36>(yesno [-q] ['prompt'])

C<yesno> will prompt and wait for either a 'Y' or an 'N' as input. Anything
else will be ignored and the user will be reprompted. Without C<-q>, an
invalid input also prints a warning to stderr.

Options:
  -q, --quiet   Suppress the "Please enter a Y or a N" warning on invalid input
  -h, --help    Show this help

C<yesno> accepts an optional value that will be used as the prompt. If nothing
is passed in, the default prompt is 'Yes or no?'.

=cut
POD

#-----------------------------------------------------------------------------
quiet=0

while [[ ${1-} == -* ]]; do
  case $1 in
    -q | --quiet) quiet=1 ; shift ;;
    -h | --help) usage ;;
    *) warn "Unknown option: $1" ; exit 2 ;;
  esac
done

declare -u yn

while true; do
  read -rN1 -p "${1:-Yes or no?} " yn

  case $yn in
    Y | N)
      printf '%s' "$yn"
      exit 0
      ;;
    *)
      ((quiet)) || warn 'Please enter a Y or a N'
      ;;
  esac
done
