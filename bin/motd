#!/usr/bin/env bash
# System summary for MOTD ‚Äî suitable for ~/.bashrc or /etc/update-motd.d/

set -euo pipefail

has() { command -v "$1" &> /dev/null; }

if has ansi; then
  c_label=$(ansi fg cyan)
  c_warn=$(ansi fg yellow)
  c_alert=$(ansi fg red)
  c_ok=$(ansi fg green)
  c_off=$(ansi off)
else
  c_label=$'\033[0;36m'
  c_warn=$'\033[0;33m'
  c_alert=$'\033[0;31m'
  c_ok=$'\033[0;32m'
  c_off=$'\033[0m'
fi

lbl() { printf '%s%-22s%s' "$c_label" "$1" "$c_off"; }

printf '\n'

#-----------------------------------------------------------------------------
# System load
if [[ -r /proc/loadavg ]]; then
  read -r l1 l5 l15 _ < /proc/loadavg
  ncpu=$(nproc 2> /dev/null || grep -c '^processor' /proc/cpuinfo 2> /dev/null || echo 1)

  load_color=$c_ok
  if awk -v l="$l15" -v n="$ncpu" 'BEGIN{exit !(l+0 > n+0)}'; then
    load_color=$c_warn
  fi
  if awk -v l="$l15" -v n="$ncpu" 'BEGIN{exit !(l+0 > n*2)}'; then
    load_color=$c_alert
  fi

  printf '%s %s%s%s (1m)  %s%s%s (5m)  %s%s%s (15m)\n' \
    "$(lbl 'System load:')" \
    "$load_color" "$l1" "$c_off" \
    "$load_color" "$l5" "$c_off" \
    "$load_color" "$l15" "$c_off"
fi

#-----------------------------------------------------------------------------
# Disk usage (real filesystems only)
printf '%s\n' "$(lbl 'Disk usage:')"
df -h --output=target,size,used,avail,pcent 2> /dev/null \
  | awk 'NR>1 && $1!~/^(tmpfs|devtmpfs|udev|\/dev\/loop|\/snap\/)/' \
  | while IFS= read -r line; do
    pct=$(awk '{print $5}' <<< "$line" | tr -d '%')
    color=$c_ok
    if [[ -n $pct ]] && ((pct >= 90)); then
      color=$c_alert
    elif [[ -n $pct ]] && ((pct >= 80)); then
      color=$c_warn
    fi
    printf '  %s%s%s\n' "$color" "$line" "$c_off"
  done

#-----------------------------------------------------------------------------
# IP addresses
mapfile -t ips < <(ip -o addr show scope global 2> /dev/null | awk '{print $2": "$4}')
if ((${#ips[@]} > 0)); then
  printf '%s\n' "$(lbl 'IP addresses:')"
  for ip in "${ips[@]}"; do
    printf '  %s\n' "$ip"
  done
fi

#-----------------------------------------------------------------------------
# Zombie processes
zombie_count=$(awk '$3 == "Z" {c++} END {print c+0}' /proc/[0-9]*/stat 2> /dev/null)
if ((zombie_count > 0)); then
  plural='es'
  ((zombie_count == 1)) && plural=''
  printf '%s %s%d zombie process%s%s\n' \
    "$(lbl 'Zombies:')" \
    "$c_alert" "$zombie_count" "$plural" "$c_off"
fi

#-----------------------------------------------------------------------------
# Available updates
# Prefer the pre-computed Ubuntu update-notifier data (fast); fall back to apt
updates_msg=''
if [[ -x /usr/lib/update-notifier/apt-check ]]; then
  pkg_updates=0
  security_updates=0
  read -r pkg_updates security_updates < <(
    /usr/lib/update-notifier/apt-check 2>&1 | tr ';' ' '
  ) || true
  if ((pkg_updates > 0)); then
    updates_msg="${pkg_updates} update(s) available"
    if ((security_updates > 0)); then
      updates_msg+=" (${security_updates} security)"
    fi
  fi
elif has apt; then
  pkg_updates=$(apt list --upgradable 2> /dev/null | grep -c '/' || true)
  if ((pkg_updates > 0)); then
    updates_msg="${pkg_updates} update(s) available"
  fi
fi

if [[ -n $updates_msg ]]; then
  printf '%s %s%s%s\n' "$(lbl 'Updates:')" "$c_warn" "$updates_msg" "$c_off"
fi

#-----------------------------------------------------------------------------
# Linode VPS ‚Äî detect and check kernel
is_linode=false
for _f in /sys/class/dmi/id/sys_vendor /sys/class/dmi/id/board_vendor \
  /sys/class/dmi/id/chassis_vendor; do
  if [[ -r $_f ]]; then
    _v=$(< "$_f")
    if [[ ${_v,,} == *linode* ]]; then
      is_linode=true
      break
    fi
  fi
done

if $is_linode; then
  running_kernel=$(uname -r)
  printf '%s %sLinode VPS%s  kernel: %s\n' \
    "$(lbl 'Platform:')" "$c_ok" "$c_off" "$running_kernel"

  # Check if a newer kernel is installed but not yet running
  latest_installed=$(find /boot -maxdepth 1 -name 'vmlinuz-*' 2> /dev/null \
    | sort -V | tail -1 | sed 's|.*/vmlinuz-||')
  if [[ -n $latest_installed && $latest_installed != "$running_kernel" ]]; then
    printf '  %sInstalled kernel %s is newer ‚Äî reboot to apply%s\n' \
      "$c_warn" "$latest_installed" "$c_off"
  fi

  # Check for kernel package updates available via apt
  if has apt; then
    kernel_pkg_updates=$(apt list --upgradable 2> /dev/null \
      | grep -c 'linux-image' || true)
    if ((kernel_pkg_updates > 0)); then
      printf '  %s%d kernel package update(s) available%s\n' \
        "$c_warn" "$kernel_pkg_updates" "$c_off"
    fi
  fi
fi

printf '\n'
