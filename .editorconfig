root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# shfmt reads these and applies them when processing shell files. They're
# shfmt-specific (other editors ignore them). Keeping them in [*] means
# extension-less shell scripts in bin/, lib/, config/shell-startup/, etc.
# are covered without enumerating paths. `-s` (simplify) has no
# editorconfig equivalent and must stay on the CLI.
binary_next_line = true
switch_case_indent = true
space_redirects = true

[*.md]
# Trailing double-space is a line break in Markdown; preserve it.
trim_trailing_whitespace = false

[{Makefile,*.mk}]
indent_style = tab

[*.py]
indent_size = 4

[*.go]
indent_style = tab
