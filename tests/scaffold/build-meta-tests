#!/usr/bin/env bash

# Generate per-file "meta" tests — static checks that validate a script
# without executing it — for the scripts under the given roots. The checks
# are language-specific: bash/sh -> shebang + bash -n + shellcheck + shfmt;
# perl -> shebang + perl -c; python -> shebang + compile(). Self-contained:
# no external library, no repo-specific assumptions beyond "scripts live
# under <root>/<dir>". Portable to any repo that drops in tests/scaffold +
# the helpers + bats-toolbox.
#
# Usage:
#   tests/scaffold/build-meta-tests [DIR ...]
#
# DIR arguments are roots to scan, relative to the repo root
# (default: bin lib config/claude/skills — the last covers skill helper
# scripts like config/claude/skills/*/scripts/*; non-scripts are skipped).
# Output: one <dir>-<name>.meta.bats per script, written to tests/shell/ (which
# gitignores *.meta.bats). Files listed in tests/scaffold/meta-ignore (one
# repo-relative path per line, # comments allowed) are skipped.
#
# Symlinks are ignored (find -type f), so multi-call dispatchers like
# bin/docker_wrapper are tested once and their tool symlinks are not.

set -euo pipefail

warn() { printf 'build-meta-tests: %s\n' "$*" >&2; }
die() {
  warn "$@"
  exit 1
}

#------------------------------------------------------------------------------
# Locate ourselves and the repo (tests/scaffold/build-meta-tests -> ../..).

self=$(readlink -f "$0")
scaffold_dir=$(dirname "$self")
root=$(cd "$scaffold_dir/../.." && pwd)

template_dir="$scaffold_dir/templates"
ignore_file="$scaffold_dir/meta-ignore"
out_dir="$root/tests/shell"

# Preload one template per supported language (file.meta.<lang>.bats.template).
declare -A templates=()
for lang in bash perl python; do
  tf="$template_dir/file.meta.$lang.bats.template"
  [[ -f $tf ]] && templates[$lang]=$(< "$tf")
done
((${#templates[@]})) || die "no templates found in $template_dir"

mkdir -p "$out_dir"

#------------------------------------------------------------------------------
# Roots to scan (repo-relative); default to bin + lib + skill helper scripts.

declare -a roots=("$@")
((${#roots[@]})) || roots=(bin lib config/claude/skills)

#------------------------------------------------------------------------------
# Load the ignore list (repo-relative paths) into a set.

declare -A ignore=()
if [[ -f $ignore_file ]]; then
  while IFS= read -r line; do
    line=${line%%#*}
    line=${line//[[:space:]]/}
    [[ -n $line ]] && ignore[$line]=1
  done < "$ignore_file"
fi

#------------------------------------------------------------------------------
# Collect candidate files (real files only — symlinks excluded).

declare -a files=()
for r in "${roots[@]}"; do
  if [[ ! -d $root/$r ]]; then
    warn "skipping missing root: $r"
    continue
  fi

  while IFS= read -r -d '' f; do
    files+=("$f")
  done < <(find "$root/$r" -type f -print0)
done

((${#files[@]})) || die "no files found under: ${roots[*]}"

#------------------------------------------------------------------------------
# Generate a meta test per shell script.

declare -i count=0
declare -A generated=()
for f in "${files[@]}"; do
  rel=${f#"$root"/}

  [[ -n ${ignore[$rel]-} ]] && continue

  # Classify by shebang, then by extension; skip anything we can't place.
  shebang=$(head -n 1 "$f")
  case $shebang in
    '#!'*sh*) lang=bash ;;
    '#!'*perl*) lang=perl ;;
    '#!'*python*) lang=python ;;
    *)
      case $f in
        *.sh | *.bash) lang=bash ;;
        *.pl | *.pm) lang=perl ;;
        *.py) lang=python ;;
        *) continue ;;
      esac
      ;;
  esac

  template=${templates[$lang]-}
  [[ -n $template ]] || {
    warn "no template for lang=$lang, skipping: $rel"
    continue
  }

  name=${rel//\//-}
  out="$out_dir/${name}.meta.bats"

  printf '%s\n' "${template//'{{REL_PATH}}'/$rel}" > "$out"
  generated["${name}.meta.bats"]=1
  ((++count))
done

#------------------------------------------------------------------------------
# Prune stale meta tests: any *.meta.bats in out_dir that we did NOT (re)generate
# this run — its source was renamed, deleted, added to meta-ignore, or is no
# longer a recognized script. Only *.meta.bats are matched, so hand-written
# test_*.bats are never touched.

declare -i pruned=0
shopt -s nullglob
for existing in "$out_dir"/*.meta.bats; do
  [[ -n ${generated[${existing##*/}]-} ]] && continue

  rm -f "$existing"
  ((++pruned))
done
shopt -u nullglob

warn "generated $count meta test(s), pruned $pruned stale, into ${out_dir#"$root"/}"
