# Allowlist for config/: deny everything, then re-include only what we
# track. Each allowed subdirectory owns its own .gitignore in the same
# deny-all/allow-specific format.

/*

# Tracked top-level files
!/flake8
!/.gitignore
!/gnome-initial-setup-done
!/hadolint.yaml
!/shellcheckrc
!/user-dirs.dirs
!/.vintrc.yaml

# Allowed subdirectories (each manages its own contents)
!/claude/
!/ansible/
!/binenv/
!/burn-my-windows/
!/completions/
!/gh/
!/git/
!/glow/
!/htop/
!/npm/
!/opencode/
!/perl/
!/pgcli/
!/pudb/
!/pypoetry/
!/python/
!/readline/
!/rustup/
!/shell-startup/
!/task/
!/tmux/
!/yamllint/
!/yapf/
