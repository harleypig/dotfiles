# shellcheck shell=bash

havecmd ansible || return 0

export ANSIBLE_HOME="$XDG_CONFIG_HOME/ansible"
export ANSIBLE_CONFIG="$ANSIBLE_HOME/ansible.cfg"

# The brace lists must sit OUTSIDE the quotes to expand (previously quoted, so
# this created single dirs literally named "{tmp,galaxy}" / "{...}").
# shellcheck disable=SC2174  # 0700 on the leaf dirs we create here is intended
mkdir -pm 0700 \
  "$XDG_CACHE_HOME/ansible/"{tmp,galaxy} \
  "$XDG_DATA_HOME/ansible/"{collections,inventory,roles}
