# shellcheck shell=bash

# node/npm XDG environment — set whenever the tool is present, independent of
# the nvm-vs-system PATH branch below. (Consolidated here from app_env_vars so
# all node/npm setup lives in one module.)
havecmd node && export NODE_REPL_HISTORY="$XDG_CACHE_HOME/node_repl_history"

if havecmd npm; then
  export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
  export npm_config_cache="$XDG_CACHE_HOME/npm"
fi

# nvm + its Node versions live under XDG_DATA_HOME (runtime data, not config),
# where `vmgr install node` puts them. Lazy-load it here at login.
if [[ -f $XDG_DATA_HOME/nvm/nvm.sh ]]; then
  export NVM_DIR="$XDG_DATA_HOME/nvm"
  [[ -s $NVM_DIR/nvm.sh ]] && source "$NVM_DIR/nvm.sh"
  [[ -s $NVM_DIR/bash-completion ]] && source "$NVM_DIR/bash-completion"
  [[ -s $DOTFILES/nvm_nodejs_org_mirror ]] && source "$DOTFILES/nvm_nodejs_org_mirror"
  addpath "$XDG_DATA_HOME/npm/bin"

elif havecmd npm; then
  mkdir -p "$XDG_DATA_HOME/npm/bin"
  mkdir -p "$XDG_DATA_HOME/npm/lib/node_modules"
  addpath "$XDG_DATA_HOME/npm/bin"
fi

# npm bash completion — vendored from `npm completion` into
# config/completions/npm (sourcing the static file avoids forking npm, which
# measured ~270ms, on every interactive shell). Interactive-only; regenerate
# on upgrade — see config/completions/README.md.
[[ $- == *i* ]] && havecmd npm \
  && [[ -r "$XDG_CONFIG_HOME/completions/npm" ]] \
  && source "$XDG_CONFIG_HOME/completions/npm"
