# shellcheck shell=bash

#-----------------------------------------------------------------------------
# binenv environment configuration
# Binary environment manager for installing binaries

if havecmd binenv; then
  # Set binenv environment variables following XDG Base Directory specification
  export BINENV_CACHEDIR="$XDG_CACHE_HOME/binenv"
  export BINENV_CONFDIR="$XDG_CONFIG_HOME/binenv"
  export BINENV_LINKDIR="$HOME/.local/bin"

  # Create directories if they don't exist
  #mkdir -p "$BINENV_BINDIR"
  mkdir -p "$BINENV_CACHEDIR"
  mkdir -p "$BINENV_CONFDIR"
  mkdir -p "$BINENV_LINKDIR"

  # Enable bash completion for binenv
  source <(binenv completion bash)
fi
