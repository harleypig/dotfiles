# shellcheck shell=bash

export GOPATH="${XDG_DATA_HOME}/go"

havecmd go || return 0

#----------------------------------------------------------------------
if [ -z "$GOBIN" ]; then
  if [ -n "$(go env GOBIN)" ]; then
    GOBIN="$(go env GOBIN)"
    export GOBIN
  else
    export GOBIN="$GOPATH/bin"
  fi

  mkdir -p "$GOBIN"
  addpath "$GOBIN"
fi
