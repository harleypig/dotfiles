# Convention: prefer directory-local .gitignore over path-prefixed rules here.
# Rules in this file should be either truly global (apply anywhere in the repo)
# or specific to the repo root itself.

# coverage?
coverage

.env

*.swp
*~

venv

node_modules/**
cygdrive/**

package-lock.json
package.json
nvm_nodejs_org_mirror

# Ignore VSCode syncsettings UI state
.vscode/syncsettings/profiles/default/data/ui-state.yml

# Claude Code personal/local settings
**/.claude/settings.local.json
